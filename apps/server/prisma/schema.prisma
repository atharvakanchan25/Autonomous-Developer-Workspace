generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id          String      @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  tasks       Task[]
  aiPlanLogs  AiPlanLog[]

  @@map("projects")
}

model Task {
  id           String     @id @default(cuid())
  title        String
  description  String?
  status       TaskStatus @default(PENDING)
  order        Int        @default(0)
  projectId    String
  project      Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  // Self-relation for DAG dependencies
  dependsOn    Task[]     @relation("TaskDependencies")
  dependents   Task[]     @relation("TaskDependencies")
  agentRuns    AgentRun[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@map("tasks")
}

// Audit log — stores raw LLM input/output for every plan generation
model AiPlanLog {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  prompt      String
  rawResponse String
  taskCount   Int
  createdAt   DateTime @default(now())

  @@map("ai_plan_logs")
}

// Persists every agent execution — input, output, status, duration
model AgentRun {
  id          String        @id @default(cuid())
  taskId      String
  task        Task          @relation(fields: [taskId], references: [id], onDelete: Cascade)
  agentType   AgentType
  status      AgentRunStatus @default(RUNNING)
  input       String        // JSON-serialised AgentContext
  output      String?       // JSON-serialised AgentResult
  errorMsg    String?
  durationMs  Int?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@map("agent_runs")
}

enum AgentType {
  CODE_GENERATOR
  TEST_GENERATOR
  CODE_REVIEWER
}

enum AgentRunStatus {
  RUNNING
  COMPLETED
  FAILED
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
}

// Structured observability log — written by every significant server event
model ObservabilityLog {
  id         String   @id @default(cuid())
  level      LogLevel
  source     String   // e.g. "agent", "queue", "task", "pipeline"
  message    String
  taskId     String?
  projectId  String?
  agentRunId String?
  agentType  String?
  durationMs Int?
  meta       String?  // JSON blob for arbitrary extra fields
  createdAt  DateTime @default(now())

  @@index([projectId, createdAt])
  @@index([level, createdAt])
  @@index([source, createdAt])
  @@map("observability_logs")
}

enum LogLevel {
  DEBUG
  INFO
  WARN
  ERROR
}
