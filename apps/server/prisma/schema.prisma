generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id          String      @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  tasks       Task[]
  aiPlanLogs  AiPlanLog[]

  @@map("projects")
}

model Task {
  id           String     @id @default(cuid())
  title        String
  description  String?
  status       TaskStatus @default(PENDING)
  order        Int        @default(0)
  projectId    String
  project      Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  // Self-relation for DAG dependencies
  dependsOn    Task[]     @relation("TaskDependencies")
  dependents   Task[]     @relation("TaskDependencies")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@map("tasks")
}

// Audit log — stores raw LLM input/output for every plan generation
model AiPlanLog {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  prompt      String
  rawResponse String
  taskCount   Int
  createdAt   DateTime @default(now())

  @@map("ai_plan_logs")
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
}
