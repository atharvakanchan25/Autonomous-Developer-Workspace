# ── Application ──────────────────────────────────────────────────────────────
NODE_ENV="development"
PORT=4000

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/adw_db?schema=public"

# ── Redis ─────────────────────────────────────────────────────────────────────
# Use rediss:// for TLS (Redis Cloud, Upstash, etc.)
REDIS_URL="redis://localhost:6379"

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY="sk-your-openai-api-key-here"

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGIN="http://localhost:3000"

# ── Logging ───────────────────────────────────────────────────────────────────
# Options: debug | info | warn | error
LOG_LEVEL="info"

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=200
