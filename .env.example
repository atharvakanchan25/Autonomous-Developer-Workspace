# Groq API Configuration
GROQ_API_KEY=your-groq-api-key-here

# Firebase Configuration
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Admin Configuration
ADMIN_EMAILS=admin@example.com,another-admin@example.com

# Server Configuration
APP_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:3000

# Docker port bindings — each developer sets unique ports to avoid conflicts
BACKEND_PORT=4000
FRONTEND_PORT=3000
REDIS_PORT=6379

# Unique name per developer so containers don't collide on the shared server
COMPOSE_PROJECT_NAME=adw-yourname

# Logging
LOG_LEVEL=info

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=200

# ── New: Orchestrator / Agent Platform ────────────────────────────────────────

# Git Integration (optional — leave blank to disable)
GITHUB_TOKEN=
GITHUB_REPO=owner/repo
GIT_AUTHOR_NAME=ADW Bot
GIT_AUTHOR_EMAIL=adw-bot@autonomous-dev.ai

# Vector Memory — Qdrant (optional — leave blank to use Firestore fallback)
QDRANT_URL=

# Graph Memory — Neo4j (optional — leave blank to use Firestore fallback)
NEO4J_URI=
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# Vercel Deployment (optional)
VERCEL_TOKEN=

# Frontend Vercel URL — set this on the backend so CORS allows your Vercel deployment
FRONTEND_URL=https://your-app.vercel.app

# Frontend env vars (set these in Vercel dashboard or frontend/.env.local)
NEXT_PUBLIC_API_URL=https://your-backend.onrender.com
NEXT_PUBLIC_SOCKET_URL=https://your-backend.onrender.com
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
