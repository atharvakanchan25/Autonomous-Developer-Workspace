# Groq API Configuration
GROQ_API_KEY=your-groq-api-key-here

# Firebase Configuration
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Admin Configuration
ADMIN_EMAILS=admin@example.com,another-admin@example.com

# Server Configuration
APP_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:3000

# Docker port bindings — each developer sets unique ports to avoid conflicts
# e.g. developer A: BACKEND_PORT=4001, FRONTEND_PORT=3001
BACKEND_PORT=4000
FRONTEND_PORT=3000

# Unique name per developer so containers don't collide on the shared server
COMPOSE_PROJECT_NAME=adw-yourname

# Logging
LOG_LEVEL=info

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=200
